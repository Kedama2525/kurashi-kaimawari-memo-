---
const { updated, published } = Astro.props as {
  updated?: string;
  published?: string;
};

const displayDate = updated || published;
const formattedDate = displayDate
  ? displayDate.replace(/^(\d{4})-(\d{2})-(\d{2})$/, (_, year, month, day) => {
      return `${Number(year)}年${Number(month)}月${Number(day)}日`;
    })
  : "";
---

<div class="affiliate-notice">
  <span class="affiliate-notice__label">PR</span>
  {displayDate && (
    <time class="affiliate-notice__date" datetime={displayDate}>更新日: {formattedDate}</time>
  )}
</div>
